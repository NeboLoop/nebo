{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Nebo",
  "version": "0.12.4",
  "identifier": "dev.neboai.nebo",
  "build": {
    "beforeDevCommand": "cd ../app && pnpm dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../app/build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "bundled-napps/**/*": "bundled-napps/"
    },
    "externalBin": [
      "binaries/obscura",
      "binaries/obscura-worker"
    ],
    "macOS": {
      "entitlements": "../assets/macos/nebo.entitlements",
      "hardenedRuntime": true
    }
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
