/target
# Packaged app build output (Tauri bundle, incl. the signed obscura-worker
# sidecar). Generated by `make build-desktop` / CI, never committed — a single
# platform's binary is the wrong one for the others and breaks notarization.
/dist/
.env
*.db
*.db-journal
*.db-wal
*.db-shm
.DS_Store
.claude/
/extensions
.fix
.plans/
# Internal docs are not for the public repo — only publishers-guide is public.
# (Kept on disk; withheld from the tree so nothing internal ships when this repo
# goes public. Opt specific docs back in by force-adding them.)
docs/*
!docs/publishers-guide/
results*/
.testing/
overrides/
.nebo/
.understand-anything/

# Playwright MCP screenshot scratch output
.playwright-mcp/

# Bundled plugin binaries are CDN-fetched at CI, never committed (can be 100s of MB)
src-tauri/bundled-napps/plugins/*/

# Obscura (and other) Tauri externalBin sidecars: staged from the localrivet fork
# build (make stage-obscura) or fetched from fork release assets at CI. Never committed.
src-tauri/binaries/
