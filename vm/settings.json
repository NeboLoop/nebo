{
  "network": {
    "allowedDomains": [
      "registry.npmjs.org",
      "npmjs.com",
      "yarnpkg.com",
      "registry.yarnpkg.com",
      "pypi.org",
      "files.pythonhosted.org",
      "github.com",
      "api.anthropic.com",
      "anthropic.com",
      "crates.io",
      "index.crates.io",
      "static.crates.io",
      "neboai.com",
      "api.neboai.com"
    ],
    "deniedDomains": [],
    "allowLocalBinding": true,
    "allowAllUnixSockets": false
  },
  "filesystem": {
    "denyRead": [],
    "allowWrite": ["/sessions", "/tmp"],
    "denyWrite": ["/usr", "/bin", "/sbin", "/etc"]
  }
}
